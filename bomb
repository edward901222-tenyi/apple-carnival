import tkinter as tk
import random
from tkinter import messagebox

class Minesweeper:
    def __init__(self, root, rows=10, cols=10, mines=12):
        self.root = root
        self.root.title("經典踩地雷")
        
        self.rows = rows
        self.cols = cols
        self.mines_count = mines
        
        self.buttons = {}
        self.mines = set()
        self.revealed = set()
        self.flags = set()
        self.game_over = False
        
        self.create_widgets()
        self.reset_game()

    def create_widgets(self):
        # 建立上方資訊欄
        self.info_frame = tk.Frame(self.root)
        self.info_frame.pack(side=tk.TOP, fill=tk.X, pady=5)
        
        self.label_mines = tk.Label(self.info_frame, text=f"地雷數: {self.mines_count}", font=("Helvetica", 12))
        self.label_mines.pack(side=tk.LEFT, padx=10)
        
        self.btn_restart = tk.Button(self.info_frame, text="😊 重新開始", command=self.reset_game, font=("Helvetica", 10))
        self.btn_restart.pack(side=tk.RIGHT, padx=10)
        
        # 建立遊戲棋盤網格
        self.grid_frame = tk.Frame(self.root)
        self.grid_frame.pack()
        
        for r in range(self.rows):
            for c in range(self.cols):
                # 建立按鈕，並綁定滑鼠左鍵與右鍵事件
                btn = tk.Button(self.grid_frame, width=3, height=1, font=("Helvetica", 12, "bold"), relief="raised")
                btn.grid(row=r, column=c)
                btn.bind("<Button-1>", lambda event, row=r, col=c: self.left_click(row, col))
                btn.bind("<Button-3>", lambda event, row=r, col=c: self.right_click(row, col))
                self.buttons[(r, c)] = btn

    def reset_game(self):
        self.mines.clear()
        self.revealed.clear()
        self.flags.clear()
        self.game_over = False
        self.btn_restart.config(text="😊 重新開始")
        self.label_mines.config(text=f"地雷數: {self.mines_count}")
        
        # 隨機放置地雷
        all_positions = [(r, c) for r in range(self.rows) for c in range(self.cols)]
        self.mines = set(random.sample(all_positions, self.mines_count))
        
        # 重設所有按鈕外觀
        for (r, c), btn in self.buttons.items():
            btn.config(text="", bg="SystemButtonFace", relief="raised", state="normal")

    def get_neighbors(self, r, c):
        # 獲取周圍 8 個格子的座標
        neighbors = []
        for dr in [-1, 0, 1]:
            for dc in [-1, 0, 1]:
                if dr == 0 and dc == 0:
                    continue
                nr, nc = r + dr, c + dc
                if 0 <= nr < self.rows and 0 <= nc < self.cols:
                    neighbors.append((nr, nc))
        return neighbors

    def count_around_mines(self, r, c):
        # 計算周圍有幾顆雷
        return sum(1 for nr, nc in self.get_neighbors(r, c) if (nr, nc) in self.mines)

    def left_click(self, r, c):
        if self.game_over or (r, c) in self.revealed or (r, c) in self.flags:
            return
        
        # 踩到地雷，遊戲結束
        if (r, c) in self.mines:
            self.show_all_mines()
            self.btn_restart.config(text="😵 失敗")
            self.game_over = True
            messagebox.showinfo("Game Over", "逼逼！你踩到地雷了！")
            return
        
        # 安全格，開始翻開
        self.reveal(r, c)
        
        # 檢查是否獲勝
        if len(self.revealed) + len(self.mines) == self.rows * self.cols:
            self.btn_restart.config(text="😎 獲勝")
            self.game_over = True
            messagebox.showinfo("Congratulations!", "太厲害了！你成功拆除所有地雷！")

    def reveal(self, r, c):
        if (r, c) in self.revealed:
            return
        self.revealed.add((r, c))
        
        around_mines = self.count_around_mines(r, c)
        btn = self.buttons[(r, c)]
        
        # 設定不同數字的顏色
        colors = {1: "blue", 2: "green", 3: "red", 4: "darkblue", 5: "darkred", 6: "cyan", 7: "purple", 8: "black"}
        
        if around_mines > 0:
            btn.config(text=str(around_mines), bg="#e6e6e6", relief="sunken", fg=colors.get(around_mines, "black"))
        else:
            # 如果周圍沒有雷，點擊會自動擴展擴散
            btn.config(text="", bg="#e6e6e6", relief="sunken")
            for nr, nc in self.get_neighbors(r, c):
                if (nr, nc) not in self.revealed and (nr, nc) not in self.flags:
                    self.reveal(nr, nc)

    def right_click(self, r, c):
        if self.game_over or (r, c) in self.revealed:
            return
        
        btn = self.buttons[(r, c)]
        if (r, c) in self.flags:
            # 取消插旗
            self.flags.remove((r, c))
            btn.config(text="", fg="black")
            self.label_mines.config(text=f"地雷數: {self.mines_count - len(self.flags)}")
        else:
            # 插旗
            self.flags.add((r, c))
            btn.config(text="🚩", fg="red")
            self.label_mines.config(text=f"地雷數: {self.mines_count - len(self.flags)}")

    def show_all_mines(self):
        # 遊戲結束時顯現所有地雷的位置
        for (r, c) in self.mines:
            if (r, c) in self.flags:
                self.buttons[(r, c)].config(text="🚩", bg="#ffcccc")
            else:
                self.buttons[(r, c)].config(text="💣", bg="#ffcccc")

if __name__ == "__main__":
    root = tk.Tk()
    # 預設 10x10 的地圖，內含 12 顆地雷
    game = Minesweeper(root, rows=10, cols=10, mines=12)
    root.mainloop()
